          "lastSeen": "2026-05-20T00:00:01.000Z",
          "seenRel": "now",
          "paired": false
        }
      ]
    },
    "expected": {
      "urls": [],
      "names": [],
      "sources": [],
      "warnings": [],
      "fetchCalls": 1
    }
  }
]
